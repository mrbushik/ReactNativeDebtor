{
  "name": "react-native-debtor",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "start": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs",
    "start:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --clear",
    "android": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --android",
    "android:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --android --clear",
    "ios": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --ios",
    "ios:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --ios --clear",
    "web": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --web",
    "web:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --web --clear",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,mts,cts}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,mts,cts}\"",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --coverage --runInBand",
    "validate": "npm run lint && npm run typecheck && npm run format:check && npm test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native/virtualized-lists": "^0.81.5",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.17.0",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-location": "~19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.77.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "^24.10.1",
    "@types/react": "~19.1.8",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "jest-junit": "^17.0.0",
    "prettier": "3.8.3",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "cacheDirectory": "<rootDir>/.tmp/jest-cache",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "<rootDir>/reports",
          "outputName": "junit.xml"
        }
      ]
    ],
    "watchman": false
  }
}
