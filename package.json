{
  "name": "react-native-debtor",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "start": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs",
    "start:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --clear",
    "android": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --android",
    "android:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --android --clear",
    "ios": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --ios",
    "ios:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --ios --clear",
    "web": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --web",
    "web:clear": "npm run build:scripts --silent && node .tsbuild/scripts/start-expo.mjs --web --clear"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-native/virtualized-lists": "^0.81.5",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.17.0",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-secure-store": "^56.0.4",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.77.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "~19.1.8",
    "babel-preset-expo": "~54.0.11",
    "prettier": "3.8.3",
    "typescript": "~5.9.2"
