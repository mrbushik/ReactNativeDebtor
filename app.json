{
  "expo": {
    "name": "ReactNativeDebtor",
    "slug": "react-native-debtor",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "com.mrbushik.reactnativedebtor"
    },
    "platforms": ["ios", "android", "web"],
    "scheme": "reactnativedebtor",
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ReactNativeDebtor to use your location to confirm that the service is available in your region."
        }
      ],
      "expo-secure-store"
    ],
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "eas": {
        "projectId": "94d289da-45b3-48d5-823a-4660aa15bb6b"
      }
    }
  }
}
